{
  "manifest_version": 3,
  "name": "YomiRuby",
  "version": "1.1.0",
  "description": "Annotate Japanese text with furigana using ruby tags and an offline local dictionary.",
  "action": {
    "default_title": "YomiRuby",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png",
      "256": "icons/icon256.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://jlp.yahooapis.jp/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "utils/constants.js",
        "utils/japanese.js",
        "utils/i18n.js",
        "utils/dom.js",
        "utils/ruby.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
